{{- $pages := where .Site.Pages "Type" "in" site.Params.mainSections -}}
[
{{- range $i, $page := $pages -}}
  {{- if gt $i 0 }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "description": {{ $page.Params.description | default "" | jsonify }},
    "content": {{ $page.Plain | jsonify }},
    "url": {{ $page.RelPermalink | jsonify }}
  }
{{- end -}}
]
